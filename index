// ── NAVIGATION ──
function nav(el, view) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  const v = document.getElementById('view-' + view);
  if (v) v.classList.add('active');
  const titles = { dashboard:'Dashboard', agenda:'Agenda', prontuarios:'Prontuários', 'add-paciente':'Prontuário', pipeline:'Pipeline Comercial', leads:'Leads' };
  document.getElementById('page-title').textContent = titles[view] || view;
  closeDetail(); closeLeadDetail();
}

// ── MODAL MAIN ──
function openModal() { document.getElementById('modal-main').classList.add('open'); }
function openLeadModal() { document.getElementById('modal-main').classList.add('open'); switchMTab(document.querySelectorAll('.mtab')[1],'m-lead'); }
function closeModal() { document.getElementById('modal-main').classList.remove('open'); }
document.getElementById('modal-main').addEventListener('click', e => { if (e.target === document.getElementById('modal-main')) closeModal(); });

function switchMTab(el, id) {
  document.querySelectorAll('.mtab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('m-paciente').style.display = id === 'm-paciente' ? 'block' : 'none';
  document.getElementById('m-lead').style.display = id === 'm-lead' ? 'block' : 'none';
}

// ── DETAIL PANEL (paciente) ──
let currentPatient = {};
function openDetail(name, proc, tel, email, sexo, idade, grau, grafts, horario, medico, obs) {
  currentPatient = { name, proc, tel, email, sexo, idade, grau, grafts, horario, medico, obs };
  const initials = name.split(' ').filter(w=>w).slice(0,2).map(w=>w[0]).join('');
  document.getElementById('dp-av').textContent = initials;
  document.getElementById('dp-name').textContent = name;
  document.getElementById('dp-proc').textContent = proc;
  document.getElementById('dp-tel').textContent = tel;
  document.getElementById('dp-email').textContent = email;
  document.getElementById('dp-sexo').textContent = sexo;
  document.getElementById('dp-idade').textContent = idade;
  document.getElementById('dp-grau').textContent = grau;
  document.getElementById('dp-grafts').textContent = grafts;
  document.getElementById('dp-horario').textContent = horario;
  document.getElementById('dp-medico').textContent = medico;
  document.getElementById('dp-obs').value = obs || '';
  document.getElementById('detail-panel').classList.add('open');
}
function closeDetail() { document.getElementById('detail-panel').classList.remove('open'); }

function openPatientFromDetail() {
  closeDetail();
  const p = currentPatient;
  openPatient(p.name, p.idade+' · '+p.sexo, p.tel, p.email, p.grau, p.grafts, p.proc, p.medico, 'Hoje', '3', '0', 'Particular');
}

function openPatient(name, sub, tel, email, grau, grafts, proc, medico, ultimo, agend, cancel, convenio) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelector('.nav-item[onclick*="add-paciente"]').classList.add('active');
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-add-paciente').classList.add('active');
  document.getElementById('page-title').textContent = name;
  const initials = name.split(' ').filter(w=>w).slice(0,2).map(w=>w[0]).join('');
  document.getElementById('patient-header-wrap').innerHTML = `
    <div class="patient-header">
      <div class="patient-av">${initials}</div>
      <div class="patient-meta">
        <h2>${name}</h2>
        <p>👤 ${sub}</p>
