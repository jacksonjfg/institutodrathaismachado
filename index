    </div>`;
  if (document.getElementById('dp-name-input')) document.getElementById('dp-name-input').value = name;
  if (document.getElementById('dp-tel-input')) document.getElementById('dp-tel-input').value = tel;
  if (document.getElementById('dp-email-input')) document.getElementById('dp-email-input').value = email;
  switchPTab(document.querySelector('.ptab'), 'pt-info');
}

function switchPTab(el, id) {
  document.querySelectorAll('.ptab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.patient-tab-content').forEach(c => c.classList.remove('active'));
  const tc = document.getElementById(id);
  if (tc) tc.classList.add('active');
