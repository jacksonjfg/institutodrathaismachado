function renderMonthAgenda() {
  const grid = document.getElementById('month-grid');
  if (!grid) return;
  const base = new Date(agendaDate);
  const year = base.getFullYear();
  const month = base.getMonth();
  const first = new Date(year, month, 1);
  const start = new Date(first);
  start.setDate(first.getDate() - first.getDay());
  const dayNames = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  let html = dayNames.map(d => `<div class="month-head">${d}</div>`).join('');
  for (let i = 0; i < 42; i++) {
    const day = new Date(start);
    day.setDate(start.getDate() + i);
    const iso = toISO(day);
    const events = CRM_APPOINTMENTS.filter(a => a.date === iso);
    html += `<div class="month-day ${day.getMonth() !== month ? 'other-month' : ''} ${iso === selectedMonthDay ? 'selected' : ''}" onclick="selectMonthDay('${iso}')">
      <div class="month-num">${day.getDate()}</div>
      ${events.slice(0,3).map(e => `<button class="month-event" onclick="event.stopPropagation();selectMonthDay('${iso}');openAppointmentDetail('${iso}',${CRM_APPOINTMENTS.filter(a => a.date === iso).indexOf(e)})">${escapeHtml(e.start)} ${escapeHtml(e.name)}</button>`).join('')}
