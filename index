<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Instituto Dra. Thais Machado · CRM</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #B8973A;
  --gold-light: #D4AF5A;
  --gold-pale: #F5EDD6;
  --gold-border: #E8D5A0;
  --white: #FFFFFF;
  --bg: #F9F7F3;
  --sidebar-bg: #FFFFFF;
  --text: #1A1814;
  --text-2: #4A4640;
  --text-3: #8A847C;
  --text-4: #B4AEA6;
  --border: #EDE9E0;
  --border-2: #E0D9CC;
  --red: #C0392B;
  --green: #27AE60;
  --blue: #2980B9;
  --orange: #E67E22;
  --purple: #8E44AD;
  --radius: 8px;
  --radius-lg: 12px;
  --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
  --sidebar-w: 220px;
}

* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; display:flex; font-size:14px; }

/* ── SIDEBAR ── */
.sidebar {
  width:var(--sidebar-w); min-height:100vh; background:var(--sidebar-bg);
  border-right:1px solid var(--border); display:flex; flex-direction:column;
  flex-shrink:0; position:fixed; top:0; left:0; bottom:0; z-index:100;
}
.sidebar-logo {
  padding:20px 18px 16px; border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:10px;
}
.logo-mark {
  width:34px; height:34px; border-radius:8px;
  background:linear-gradient(135deg,var(--gold),var(--gold-light));
  display:flex; align-items:center; justify-content:center;
  font-family:'Playfair Display',serif; font-size:14px; font-weight:600; color:#fff;
  flex-shrink:0;
}
.logo-text { line-height:1.3; }
.logo-text strong { font-size:12px; font-weight:600; color:var(--text); display:block; }
.logo-text span { font-size:10px; color:var(--text-3); }

.nav-new-btn {
  margin:12px 14px; background:var(--gold); color:#fff; border:none;
  border-radius:var(--radius); padding:9px 14px; cursor:pointer;
  font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500;
  display:flex; align-items:center; gap:7px; width:calc(100% - 28px);
  transition:background 0.15s;
}
.nav-new-btn:hover { background:var(--gold-light); }

.nav-section { padding:6px 0; }
.nav-section-label {
  font-size:9px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase;
  color:var(--text-4); padding:8px 18px 4px;
}
.nav-item {
  display:flex; align-items:center; gap:9px; padding:8px 18px;
  cursor:pointer; font-size:13px; color:var(--text-2); transition:all 0.15s;
  border-left:2px solid transparent; user-select:none; position:relative;
}
.nav-item:hover { background:var(--gold-pale); color:var(--text); }
.nav-item.active { background:var(--gold-pale); color:var(--gold); font-weight:500; border-left-color:var(--gold); }
.nav-item .ni { font-size:15px; width:18px; text-align:center; }
.nav-badge { margin-left:auto; background:var(--gold); color:#fff; font-size:10px; font-weight:600; padding:1px 6px; border-radius:10px; }
.nav-badge.red { background:var(--red); }

.sidebar-user { margin-top:auto; padding:14px 18px; border-top:1px solid var(--border); display:flex; align-items:center; gap:10px; }
.user-av { width:30px; height:30px; border-radius:50%; background:linear-gradient(135deg,var(--gold),var(--gold-light)); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:600; color:#fff; flex-shrink:0; }
.user-info strong { font-size:12px; font-weight:500; display:block; }
.user-info span { font-size:10px; color:var(--text-3); }

/* ── MAIN ── */
.main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

/* ── TOPBAR ── */
.topbar {
  height:54px; background:var(--white); border-bottom:1px solid var(--border);
  display:flex; align-items:center; padding:0 24px; gap:14px; position:sticky; top:0; z-index:50;
}
.topbar-title { font-family:'Playfair Display',serif; font-size:20px; font-weight:500; flex:1; color:var(--text); }
.search-box {
  display:flex; align-items:center; gap:7px; background:var(--bg);
  border:1px solid var(--border-2); border-radius:var(--radius);
  padding:7px 12px; width:240px;
}
.search-box input { background:none; border:none; outline:none; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); width:100%; }
.search-box input::placeholder { color:var(--text-4); }
.btn { display:inline-flex; align-items:center; gap:6px; padding:7px 14px; border-radius:var(--radius); border:none; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; transition:all 0.15s; }
.btn-gold { background:var(--gold); color:#fff; }
.btn-gold:hover { background:var(--gold-light); }
.btn-outline { background:transparent; color:var(--gold); border:1px solid var(--gold-border); }
.btn-outline:hover { background:var(--gold-pale); }
.btn-sm { padding:5px 11px; font-size:12px; }

/* ── CONTENT ── */
.content { flex:1; padding:22px 24px; }
.view { display:none; }
.view.active { display:block; }

/* ── DASHBOARD ── */
.stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:20px; }
.stat-card {
  background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg);
  padding:18px; box-shadow:var(--shadow);
}
.stat-top { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:10px; }
.stat-icon { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; }
.stat-icon.gold { background:var(--gold-pale); }
.stat-icon.green { background:rgba(39,174,96,0.1); }
.stat-icon.blue { background:rgba(41,128,185,0.1); }
.stat-icon.orange { background:rgba(230,126,34,0.1); }
.stat-label { font-size:11px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.07em; margin-bottom:4px; }
.stat-value { font-family:'Playfair Display',serif; font-size:28px; font-weight:500; color:var(--text); line-height:1; }
.stat-sub { font-size:11px; color:var(--text-3); margin-top:6px; }
.stat-trend { display:inline-flex; align-items:center; gap:3px; font-size:11px; font-weight:500; }
.trend-up { color:var(--green); }
.trend-dn { color:var(--red); }

.dash-grid { display:grid; grid-template-columns:1fr 340px; gap:14px; }
.card { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); box-shadow:var(--shadow); }
.card-header { padding:14px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:10px; }
.card-header h3 { font-size:14px; font-weight:600; flex:1; }
.card-body { padding:16px 18px; }

/* ── AGENDA ── */
.agenda-bar {
  background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg);
  padding:12px 18px; display:flex; align-items:center; gap:14px; margin-bottom:16px; box-shadow:var(--shadow);
}
.date-nav { display:flex; align-items:center; gap:8px; }
.date-nav button { background:none; border:1px solid var(--border-2); border-radius:6px; padding:4px 10px; cursor:pointer; font-size:14px; color:var(--text-2); }
.date-nav button:hover { border-color:var(--gold); color:var(--gold); }
.date-display { font-size:13px; font-weight:600; color:var(--text); min-width:160px; }
.view-tabs { display:flex; gap:3px; margin-left:auto; }
.view-tab { padding:5px 12px; border-radius:6px; border:1px solid var(--border-2); font-size:12px; cursor:pointer; color:var(--text-3); background:none; font-family:'DM Sans',sans-serif; transition:all 0.15s; }
.view-tab.active { background:var(--gold-pale); color:var(--gold); border-color:var(--gold-border); font-weight:500; }

.agenda-table { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow); }
.ag-head { display:grid; grid-template-columns:90px 1fr 130px 200px 1fr 100px 110px; background:var(--bg); border-bottom:1px solid var(--border); }
.ag-head-cell { padding:10px 14px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; color:var(--text-3); }
.ag-row { display:grid; grid-template-columns:90px 1fr 130px 200px 1fr 100px 110px; border-bottom:1px solid var(--border); transition:background 0.12s; cursor:pointer; }
.ag-row:hover { background:var(--gold-pale); }
.ag-row:last-child { border-bottom:none; }
.ag-cell { padding:12px 14px; font-size:13px; display:flex; align-items:center; }
.ag-time { font-weight:600; color:var(--text); font-size:12px; flex-direction:column; align-items:flex-start; gap:0; }
.ag-time span { color:var(--text-3); font-weight:400; font-size:11px; }
.ag-patient-name { font-weight:500; }
.ag-patient-sub { font-size:11px; color:var(--text-3); }
.ag-proc-type { font-size:10px; text-transform:uppercase; letter-spacing:0.06em; color:var(--text-3); }
.ag-proc-name { font-weight:500; font-size:13px; }

/* ── PRONTUÁRIOS ── */
.filter-bar { display:flex; align-items:center; gap:10px; margin-bottom:16px; }
.filter-bar .search-box { width:280px; }
.filter-select { background:var(--white); border:1px solid var(--border-2); border-radius:var(--radius); padding:7px 12px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text-2); outline:none; cursor:pointer; }

.patients-table { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow); }
.pt-head { display:grid; grid-template-columns:2fr 1fr 1fr 1fr 120px 90px; background:var(--bg); border-bottom:1px solid var(--border); }
.pt-head-cell { padding:10px 16px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; color:var(--text-3); }
.pt-row { display:grid; grid-template-columns:2fr 1fr 1fr 1fr 120px 90px; border-bottom:1px solid var(--border); cursor:pointer; transition:background 0.12s; }
.pt-row:hover { background:var(--gold-pale); }
.pt-row:last-child { border-bottom:none; }
.pt-cell { padding:12px 16px; font-size:13px; display:flex; align-items:center; }
.pt-actions { gap:6px; }
.pt-actions button { background:none; border:1px solid var(--border-2); border-radius:6px; padding:4px 9px; cursor:pointer; font-size:11px; color:var(--text-2); transition:all 0.13s; }
.pt-actions button:hover { border-color:var(--gold); color:var(--gold); background:var(--gold-pale); }
.pagination { display:flex; align-items:center; justify-content:space-between; padding:12px 16px; border-top:1px solid var(--border); font-size:12px; color:var(--text-3); }
.pag-btns { display:flex; gap:4px; }
.pag-btn { background:none; border:1px solid var(--border-2); border-radius:5px; padding:4px 10px; cursor:pointer; font-size:12px; color:var(--text-2); }
.pag-btn:hover { border-color:var(--gold); color:var(--gold); }
.pag-btn.active { background:var(--gold); color:#fff; border-color:var(--gold); }

/* ── PATIENT DETAIL ── */
.patient-tabs { display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:20px; background:var(--white); border-radius:var(--radius-lg) var(--radius-lg) 0 0; border:1px solid var(--border); box-shadow:var(--shadow); overflow:hidden; }
.ptab { padding:12px 18px; font-size:13px; cursor:pointer; color:var(--text-3); border-bottom:2px solid transparent; margin-bottom:-1px; white-space:nowrap; transition:all 0.15s; background:none; border-left:none; border-right:none; border-top:none; font-family:'DM Sans',sans-serif; }
.ptab:hover { color:var(--text); background:var(--bg); }
.ptab.active { color:var(--gold); border-bottom-color:var(--gold); font-weight:500; background:var(--white); }

.patient-header { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); padding:20px; margin-bottom:14px; box-shadow:var(--shadow); display:flex; align-items:flex-start; gap:18px; }
.patient-av { width:60px; height:60px; border-radius:50%; background:linear-gradient(135deg,var(--gold-pale),var(--gold-border)); border:2px solid var(--gold-border); display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-size:22px; color:var(--gold); flex-shrink:0; }
.patient-meta h2 { font-family:'Playfair Display',serif; font-size:22px; font-weight:500; margin-bottom:3px; }
.patient-meta p { font-size:13px; color:var(--text-3); display:flex; align-items:center; gap:6px; margin-bottom:2px; }
.patient-stats { margin-left:auto; display:flex; gap:20px; }
.pstat { text-align:center; }
.pstat .val { font-family:'Playfair Display',serif; font-size:22px; font-weight:500; color:var(--text); }
.pstat .lbl { font-size:10px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.07em; margin-top:2px; }

.patient-tab-content { display:none; }
.patient-tab-content.active { display:block; }
.info-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.info-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }
.info-card { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); padding:16px; box-shadow:var(--shadow); }
.info-card h4 { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--border); }
.field-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px; }
.field { }
.field label { font-size:10px; text-transform:uppercase; letter-spacing:0.07em; color:var(--text-3); display:block; margin-bottom:3px; }
.field .val { font-size:13px; color:var(--text); font-weight:400; }
.obs-box { background:var(--bg); border:1px solid var(--border); border-radius:var(--radius); padding:10px 12px; min-height:60px; font-size:13px; color:var(--text-2); }
.hist-item { display:flex; gap:12px; padding:10px 0; border-bottom:1px solid var(--border); }
.hist-item:last-child { border-bottom:none; }
.hist-dot { width:8px; height:8px; border-radius:50%; background:var(--gold); margin-top:5px; flex-shrink:0; }
.hist-body .hb-title { font-size:13px; font-weight:500; }
.hist-body .hb-sub { font-size:11px; color:var(--text-3); margin-top:2px; }
.upload-zone { border:2px dashed var(--border-2); border-radius:var(--radius); padding:24px; text-align:center; cursor:pointer; transition:all 0.15s; }
.upload-zone:hover { border-color:var(--gold); background:var(--gold-pale); }
.upload-zone p { font-size:13px; color:var(--text-3); margin-top:6px; }

/* ── BADGES ── */
.badge { display:inline-flex; align-items:center; gap:4px; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:500; }
.badge::before { content:''; width:5px; height:5px; border-radius:50%; background:currentColor; }
.b-agendado { background:rgba(41,128,185,0.1); color:var(--blue); }
.b-atendido { background:rgba(39,174,96,0.1); color:var(--green); }
.b-desmarcado { background:rgba(230,126,34,0.1); color:var(--orange); }
.b-faltou { background:rgba(192,57,43,0.1); color:var(--red); }
.b-confirmado { background:rgba(39,174,96,0.12); color:var(--green); }
.b-novo { background:rgba(41,128,185,0.1); color:var(--blue); }
.b-pre { background:rgba(142,68,173,0.1); color:var(--purple); }
.b-orc { background:rgba(230,126,34,0.1); color:var(--orange); }
.b-neg { background:rgba(184,151,58,0.12); color:var(--gold); }
.b-fechado { background:rgba(39,174,96,0.1); color:var(--green); }
.b-perdido { background:rgba(192,57,43,0.08); color:var(--red); }
.b-quente { background:rgba(192,57,43,0.1); color:var(--red); }
.b-morno { background:rgba(230,126,34,0.1); color:var(--orange); }
.b-frio { background:rgba(41,128,185,0.1); color:var(--blue); }

.av-sm { width:32px; height:32px; border-radius:50%; background:var(--gold-pale); border:1px solid var(--gold-border); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:600; color:var(--gold); flex-shrink:0; }
.cell-patient { display:flex; align-items:center; gap:9px; }

/* ── COMERCIAL ── */
.kanban-wrap { display:flex; gap:14px; overflow-x:auto; padding-bottom:6px; }
.kanban-col { min-width:220px; flex-shrink:0; }
.kcol-head { padding:10px 12px; border-radius:var(--radius) var(--radius) 0 0; display:flex; align-items:center; justify-content:space-between; border:1px solid var(--border); border-bottom:none; background:var(--white); }
.kcol-head .cname { font-size:12px; font-weight:600; color:var(--text-2); }
.kcol-head .ccount { font-size:11px; background:var(--bg); border:1px solid var(--border); padding:1px 7px; border-radius:10px; color:var(--text-3); }
.kcol-body { background:var(--bg); border:1px solid var(--border); border-radius:0 0 var(--radius) var(--radius); padding:8px; min-height:120px; display:flex; flex-direction:column; gap:8px; }
.kcard { background:var(--white); border:1px solid var(--border); border-radius:var(--radius); padding:12px; cursor:pointer; transition:all 0.15s; box-shadow:var(--shadow); }
.kcard:hover { border-color:var(--gold-border); box-shadow:var(--shadow-md); }
.kcard .kc-name { font-size:13px; font-weight:500; margin-bottom:3px; }
.kcard .kc-proc { font-size:11px; color:var(--text-3); margin-bottom:8px; }
.kcard .kc-foot { display:flex; align-items:center; justify-content:space-between; }
.kcard .kc-val { font-size:12px; color:var(--gold); font-weight:600; }
.kcard .kc-date { font-size:11px; color:var(--text-4); }
.kcard .kc-canal { font-size:10px; color:var(--text-4); margin-top:4px; display:flex; align-items:center; gap:3px; }

.leads-table { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow); }
.lt-head { display:grid; grid-template-columns:2fr 1fr 1fr 100px 140px 100px 100px 80px; background:var(--bg); border-bottom:1px solid var(--border); }
.lt-head-cell { padding:10px 14px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; color:var(--text-3); }
.lt-row { display:grid; grid-template-columns:2fr 1fr 1fr 100px 140px 100px 100px 80px; border-bottom:1px solid var(--border); cursor:pointer; transition:background 0.12s; }
.lt-row:hover { background:var(--gold-pale); }
.lt-row:last-child { border-bottom:none; }
.lt-cell { padding:11px 14px; font-size:13px; display:flex; align-items:center; }

/* ── MODAL ── */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:200; align-items:center; justify-content:center; }
.modal-overlay.open { display:flex; }
.modal { background:var(--white); border-radius:var(--radius-lg); padding:0; width:600px; max-height:88vh; overflow-y:auto; box-shadow:var(--shadow-lg); }
.modal-head { padding:20px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; }
.modal-head h2 { font-family:'Playfair Display',serif; font-size:20px; font-weight:500; flex:1; }
.modal-close { background:none; border:none; font-size:18px; cursor:pointer; color:var(--text-3); padding:2px 6px; border-radius:4px; }
.modal-close:hover { background:var(--bg); color:var(--text); }
.modal-body { padding:20px 24px; }
.modal-foot { padding:16px 24px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:10px; }
.form-section { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:var(--text-3); margin:16px 0 10px; padding-bottom:7px; border-bottom:1px solid var(--border); }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.form-row.full { grid-template-columns:1fr; }
.form-row.three { grid-template-columns:1fr 1fr 1fr; }
.fg { display:flex; flex-direction:column; gap:4px; }
.fg label { font-size:11px; font-weight:500; color:var(--text-2); }
.fg input, .fg select, .fg textarea {
  background:var(--bg); border:1px solid var(--border-2); border-radius:var(--radius);
  padding:8px 11px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); outline:none;
  transition:border-color 0.15s;
}
.fg input:focus, .fg select:focus, .fg textarea:focus { border-color:var(--gold); background:var(--white); }
.fg select option { background:var(--white); }
.fg textarea { resize:vertical; min-height:70px; }

.modal-tabs { display:flex; gap:2px; margin-bottom:16px; background:var(--bg); padding:3px; border-radius:var(--radius); }
.mtab { flex:1; padding:7px; text-align:center; border-radius:6px; font-size:13px; cursor:pointer; color:var(--text-3); background:none; border:none; font-family:'DM Sans',sans-serif; transition:all 0.15s; }
.mtab.active { background:var(--white); color:var(--gold); font-weight:500; box-shadow:var(--shadow); }

/* ── DETAIL PANEL ── */
