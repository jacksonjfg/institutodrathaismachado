function setupCpfValidation() {
  document.querySelectorAll('input[placeholder="000.000.000-00"]').forEach(input => {
    const fg = input.closest('.fg');
    if (!fg || fg.querySelector('.cpf-alert')) return;
    const alert = document.createElement('div');
    alert.className = 'cpf-alert';
    alert.textContent = CPF_DUPLICATE_MESSAGE;
    fg.appendChild(alert);
    input.addEventListener('blur', () => validateCpfInput(input));
    input.addEventListener('input', () => {
      fg.classList.remove('has-error');
      alert.classList.remove('show');
    });
  });
}
function validateCpfInput(input) {
  const digits = onlyDigits(input.value);
  const fg = input.closest('.fg');
  const alert = fg?.querySelector('.cpf-alert');
  const isDuplicate = digits.length === 11 && CRM_PATIENTS.some(p => onlyDigits(p.cpf) === digits);
  fg?.classList.toggle('has-error', isDuplicate);
  alert?.classList.toggle('show', isDuplicate);
  return !isDuplicate;
}
function setupSaveGuard() {
  const save = Array.from(document.querySelectorAll('.modal-foot .btn-gold')).find(btn => btn.textContent.includes('Salvar'));
  if (!save || save.dataset.guardReady) return;
  save.dataset.guardReady = '1';
  save.addEventListener('click', event => {
    const activeCpf = document.querySelector('#m-paciente[style*="block"], #m-paciente:not([style*="none"])') ? document.querySelector('#m-paciente input[placeholder="000.000.000-00"]') : null;
    if (activeCpf && !validateCpfInput(activeCpf)) {
      event.preventDefault();
      event.stopImmediatePropagation();
      activeCpf.focus();
    }
  }, true);
}

function setupUploads() {
  document.querySelectorAll('.upload-zone').forEach((zone, idx) => {
    if (zone.dataset.uploadReady) return;
    zone.dataset.uploadReady = '1';
    const input = document.createElement('input');
    input.type = 'file';
    input.multiple = true;
    input.hidden = true;
    input.accept = idx === 1 ? 'video/*' : idx === 2 ? '.pdf,.doc,.docx,image/*' : 'image/*';
    zone.after(input);
    let list = zone.parentElement.querySelector('.uploaded-list');
    if (!list) {
      list = document.createElement('div');
      list.className = 'uploaded-list';
      input.after(list);
    }
    zone.addEventListener('click', () => input.click());
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragging'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('dragging'));
    zone.addEventListener('drop', e => {
      e.preventDefault();
      zone.classList.remove('dragging');
      renderUploadedFiles(list, e.dataTransfer.files);
    });
    input.addEventListener('change', () => renderUploadedFiles(list, input.files));
  });
}
function renderUploadedFiles(list, files) {
  Array.from(files || []).forEach(file => {
    const row = document.createElement('div');
    row.className = 'uploaded-file';
    row.innerHTML = `<span>✓</span><div style="flex:1"><strong>${escapeHtml(file.name)}</strong><div style="color:var(--text-3);font-size:11px">${(file.size / 1024 / 1024).toFixed(2)} MB · anexado nesta sessão</div></div>`;
    list.prepend(row);
  });
}

function setupSearches() {
  const patientSearch = document.querySelector('#view-prontuarios .search-box input');
  if (patientSearch) {
    patientSearch.placeholder = 'Buscar por nome, CPF ou telefone...';
    patientSearch.addEventListener('input', () => { patientPage = 1; renderPatients(); });
  }
  const patientButtons = document.querySelectorAll('#view-prontuarios .filter-bar .btn');
  patientButtons[0]?.addEventListener('click', renderPatients);
  patientButtons[1]?.addEventListener('click', () => { patientSearch.value = ''; patientPage = 1; renderPatients(); });
  const topSearch = document.querySelector('.topbar .search-box input');
  topSearch?.addEventListener('input', () => {
    const active = document.querySelector('.view.active')?.id;
    if (active === 'view-prontuarios') {
      patientSearch.value = topSearch.value;
      patientPage = 1;
      renderPatients();
    }
    if (active === 'view-leads') {
      leadSearch = topSearch.value;
      renderLeadsTable();
    }
  });
  const leadInput = document.querySelector('#view-leads .search-box input');
  leadInput?.addEventListener('input', () => { leadSearch = leadInput.value; renderLeadsTable(); });
  document.querySelectorAll('#view-leads .filter-select').forEach(select => select.addEventListener('change', renderLeadsTable));
}

function initEnhancements() {
  runLoader();
  setupSearches();
  setupCpfValidation();
  setupSaveGuard();
  setupUploads();
  renderPatients();
  renderAgendaList();
  renderMonthAgenda();
  renderKanban();
  renderLeadsTable();
}
document.addEventListener('DOMContentLoaded', initEnhancements);
if (document.readyState !== 'loading') initEnhancements();
})();
</script>
