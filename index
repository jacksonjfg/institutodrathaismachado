function normalizeText(value) {
  return String(value || '').normalize('NFD').replace(/[\\u0300-\\u036f]/g,'').toLowerCase();
}
function onlyDigits(value) { return String(value || '').replace(/\\D/g,''); }
function initials(name) { return String(name || '').split(' ').filter(Boolean).slice(0,2).map(w => w[0]).join('').toUpperCase(); }
function toISO(date) {
  const d = new Date(date);
  d.setHours(12,0,0,0);
  return d.toISOString().slice(0,10);
}
function brDate(iso) {
  const [y,m,d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('pt-BR', { weekday:'long', day:'2-digit', month:'long', year:'numeric' });
}
function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}
function leadTempClass(temp) {
  return temp === 'Quente' ? 'b-quente' : temp === 'Morno' ? 'b-morno' : 'b-frio';
}
function leadStageClass(stage) {
  if (stage.startsWith('Novo')) return 'b-novo';
  if (stage.startsWith('Pré')) return 'b-pre';
  if (stage.startsWith('Orçamento')) return 'b-orc';
  if (stage.startsWith('Negociação')) return 'b-neg';
  if (stage.startsWith('Fechado')) return 'b-fechado';
  return 'b-perdido';
}
function statusClass(status) { return status === 'Agendado' ? 'b-agendado' : 'b-atendido'; }

function runLoader() {
  const overlay = document.getElementById('app-loading');
  const fill = document.getElementById('loader-fill');
  const count = document.getElementById('loader-count');
  if (!overlay || !fill || !count) return;
  let value = 0;
  const timer = setInterval(() => {
    value += Math.ceil(Math.random() * 9);
    if (value >= 100) value = 100;
    fill.style.width = value + '%';
    count.textContent = value + '%';
    if (value === 100) {
      clearInterval(timer);
      setTimeout(() => overlay.classList.add('done'), 220);
    }
  }, 55);
}

